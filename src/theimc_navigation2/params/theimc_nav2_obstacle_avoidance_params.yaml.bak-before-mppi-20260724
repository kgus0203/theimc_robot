smoother_server:
  ros__parameters:
    use_sim_time: False
    smoother_plugins: ["simple_smoother"]
    simple_smoother:
      plugin: "nav2_smoother::SimpleSmoother"
      tolerance: 1.0e-10
      max_its: 1000
      do_refinement: True

local_costmap:
  local_costmap:
    ros__parameters:
      update_frequency: 10.0
      publish_frequency: 5.0
      global_frame: odom
      robot_base_frame: base_footprint
      use_sim_time: False
      rolling_window: true
      width: 3
      height: 3
      resolution: 0.06
      transform_tolerance: 0.5
      # footprint: "[[-0.35, -0.35], [-0.35, 0.35], [0.35, 0.35], [0.35, -0.35]]"
      # footprint_padding: 0.1
      robot_radius: 0.6 # 판떼기가 90에 바퀴가 나와있어서 좀 크게(0.5) -> 판 대각선 길이가 60cm이상이라 0.6으로 수정
      # Physical radius 0.6 m + 0.05 m obstacle clearance.
      footprint_padding: 0.05

      plugins: ["obstacle_layer", "inflation_layer"]

      filters: ["keepout_filter"]
      keepout_filter:
       plugin: "nav2_costmap_2d::KeepoutFilter"
       enabled: True
       filter_info_topic: "/costmap_filter_info"

      inflation_layer:
        plugin: "nav2_costmap_2d::InflationLayer"
        cost_scaling_factor: 5.0
        # 0.65 m hard footprint plus a 0.10 m traversable preference band.
        inflation_radius: 0.5

      obstacle_layer:
        plugin: "nav2_costmap_2d::ObstacleLayer"
        enabled: True
        observation_sources: scan
        footprint_clearing_enabled: true
        scan:
          topic: /scan
          max_obstacle_height: 2.0
          clearing: True
          marking: True
          data_type: "LaserScan"
          raytrace_max_range: 4.5
          raytrace_min_range: 0.15
          obstacle_max_range: 3.5
          obstacle_min_range: 0.15

      stvl_layer:
        plugin: "spatio_temporal_voxel_layer/SpatioTemporalVoxelLayer"
        enabled: true
        publish_voxel_map: true
        voxel_size: 0.05
        voxel_decay: 1.0
        observation_sources: pointcloud
        pointcloud:
          data_type: PointCloud2
          topic: /points
          reliability: 2
          marking: true
          clearing: true
          obstacle_max_range: 2.5
          obstacle_min_range: 0.2

global_costmap:
  global_costmap:
    ros__parameters:
      # Faster obstacle updates for newly appearing obstacles.
      update_frequency: 5.0
      publish_frequency: 1.0
      global_frame: map
      robot_base_frame: base_footprint
      use_sim_time: False
      # footprint: "[[-0.35, -0.35], [-0.35, 0.35], [0.35, 0.35], [0.35, -0.35]]"
      # footprint: "[[0.35, 0.25], [0.35, -0.25], [-0.35, -0.25], [-0.35, 0.25]]"
      robot_radius: 0.6 # obstacle-avoidance model: circular robot with 0.6 m radius
      # Enforce 0.05 m clearance in planning, not merely as a soft cost.
      footprint_padding: 0.05
      transform_tolerance: 0.5
      resolution: 0.06
      track_unknown_space: true

      plugins:
        ["static_layer", "obstacle_layer", "inflation_layer"]

      filters:
        ["keepout_filter", "keepout_inflation_layer"]

      keepout_filter:
        plugin: "nav2_costmap_2d::KeepoutFilter"
        enabled: true
        filter_info_topic: "/costmap_filter_info"

      # Keepout Filter가 적용된 후 실행
      keepout_inflation_layer:
        plugin: "nav2_costmap_2d::InflationLayer"
        enabled: true
        inflation_radius: 0.5
        cost_scaling_factor: 3.0

      # 기존 실제 장애물용 Inflation
      # inflation_layer:
      #   plugin: "nav2_costmap_2d::InflationLayer"
      #   enabled: true
      #   inflation_radius: 0.75
      #   cost_scaling_factor: 3.0

      static_layer:
        plugin: "nav2_costmap_2d::StaticLayer"
        map_subscribe_transient_local: True

      obstacle_layer:
        plugin: "nav2_costmap_2d::ObstacleLayer"
        enabled: True
        observation_sources: scan
        footprint_clearing_enabled: true
        scan:
          topic: /scan
          max_obstacle_height: 2.0
          clearing: True
          marking: True
          data_type: "LaserScan"
          raytrace_max_range: 4.5
          raytrace_min_range: 0.15
          obstacle_max_range: 3.5
          obstacle_min_range: 0.15

      inflation_layer:
        plugin: "nav2_costmap_2d::InflationLayer"
        cost_scaling_factor: 3.0
        # Keep the hard radius at 0.65 m and prefer paths up to 0.75 m away.
        inflation_radius: 0.5

      always_send_full_costmap: True

map_server:
  ros__parameters:
    use_sim_time: False
    yaml_filename: "map.yaml"

map_saver:
  ros__parameters:
    use_sim_time: False
    save_map_timeout: 5.0
    free_thresh_default: 0.25
    occupied_thresh_default: 0.65
    map_subscribe_transient_local: True

planner_server:
  ros__parameters:
    expected_planner_frequency: 20.0
    use_sim_time: False

    planner_plugins: ["GridBased"]

    GridBased:
      # Hybrid-A* with Reeds-Shepp motion primitives searches both
      # forward and reverse maneuvers.
      plugin: "nav2_smac_planner/SmacPlannerHybrid"
      tolerance: 0.5
      downsample_costmap: false
      downsampling_factor: 1
      allow_unknown: true
      max_iterations: 1000000
      max_on_approach_iterations: 1000
      max_planning_time: 5.0
      motion_model_for_search: "REEDS_SHEPP"
      angle_quantization_bins: 72
      analytic_expansion_ratio: 3.5
      analytic_expansion_max_length: 3.0
      minimum_turning_radius: 0.6
      # Permit useful curved reversing maneuvers while still preferring forward.
      reverse_penalty: 1.2
      change_penalty: 0.0
      non_straight_penalty: 1.2
      cost_penalty: 2.0
      retrospective_penalty: 0.015
      lookup_table_size: 20.0
      cache_obstacle_heuristic: false
      debug_visualizations: false
      
planner_server_rclcpp_node:
  ros__parameters:
    use_sim_time: False

behavior_server:
  ros__parameters:
    # twist_mux is not installed; send recovery BackUp commands directly.
    cmd_vel_topic: /cmd_vel
    costmap_topic: local_costmap/costmap_raw
    footprint_topic: local_costmap/published_footprint
    cycle_frequency: 10.0

    behavior_plugins: ["backup", "wait"]

    backup:
      plugin: "nav2_behaviors/BackUp"

    wait:
      plugin: "nav2_behaviors/Wait"

    global_frame: odom
    robot_base_frame: base_footprint
    transform_tolerance: 1.0
    use_sim_time: False
    simulate_ahead_time: 2.0
    max_rotational_vel: 0.3
    min_rotational_vel: 0.1

robot_state_publisher:
  ros__parameters:
