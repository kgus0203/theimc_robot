controller_server:
  ros__parameters:
    # Publish directly because twist_mux is not installed on this system.
    cmd_vel_topic: /cmd_vel
    use_sim_time: False
    controller_frequency: 10.0

    # 너무 작은 cmd_vel을 0으로 잘라먹지 않도록 낮춤
    min_x_velocity_threshold: 0.001
    min_y_velocity_threshold: 0.001
    min_theta_velocity_threshold: 0.001

    # goal 중간 실패를 조금 덜 민감하게
    # Allow fast replanning to replace a collision-blocked path before aborting.
    failure_tolerance: 3.0

    progress_checker_plugin: "progress_checker"
    goal_checker_plugins: ["precise_goal_checker"]
    current_goal_checker: "precise_goal_checker"
    controller_plugins: ["FollowPath"]

    precise_goal_checker:
      plugin: "nav2_controller::SimpleGoalChecker"
      xy_goal_tolerance: 0.25
      yaw_goal_tolerance: 0.25 # 1.57 # 90도
      stateful: True

    progress_checker:
      plugin: "nav2_controller::SimpleProgressChecker"
      required_movement_radius: 0.03
      movement_time_allowance: 20.0

    PathHandler:
      plugin: "nav2_controller::FeasiblePathHandler"
      prune_distance: 1.0
      enforce_path_inversion: False
      enforce_path_rotation: False
      inversion_xy_tolerance: 0.2
      inversion_yaw_tolerance: 0.4
      minimum_rotation_angle: 0.25
      reject_unit_path: False

    FollowPath:
      plugin: "nav2_regulated_pure_pursuit_controller::RegulatedPurePursuitController"

      desired_linear_vel: 0.18

      # Follow tight avoidance bends without cutting across obstacle costs.
      lookahead_dist: 0.30
      min_lookahead_dist: 0.25
      max_lookahead_dist: 0.50
      lookahead_time: 1.0
      use_velocity_scaled_lookahead_dist: false

      # 도착지점 빙글빙글 방지
      # Follow forward/reverse cusps generated by the Reeds-Shepp planner.
      # This must be false when allow_reversing is enabled.
      use_rotate_to_heading: false
      rotate_to_heading_min_angle: 0.2 # 제자리 회전을 발동시키는 각도 기준 (0.35는 약 20도) 오차가 이 값보다 크면 일단 제자리에서 방향부터 맞추게 됨
      rotate_to_heading_angular_vel: 0.3 # 제자리 회전할 때 얼마나 빠르게 돌지

      max_angular_accel: 1.0
      max_angular_decel: 1.0

      allow_reversing: true

      # Obstacle-aware speed control (enabled in this derived config)
      use_cost_regulated_linear_velocity_scaling: true
      use_regulated_linear_velocity_scaling: true
      cost_scaling_dist: 0.10
      cost_scaling_gain: 1.0
      inflation_cost_scaling_factor: 5.0
      regulated_linear_scaling_min_radius: 1.2
      regulated_linear_scaling_min_speed: 0.05
      min_approach_linear_velocity: 0.08

      # Predict collisions along the commanded path using the local costmap.
      use_collision_detection: true
      # Keep collision checking active, but avoid rejecting a safe tight curve
      # solely because of an overly long projected arc.
      max_allowed_time_to_collision_up_to_carrot: 0.8

