<!--
레일이 12개 있다고 가정하고 시나리오 테스트(현재는 모든 레일의 위치가 같게 해놓음)

0. 이걸 켤 때 내가 대충 홈위치에서 출발한다고 가정, ForEachRail로 대상 rail이 순차적으로 들어옴
1. /mission_trigger 토픽을 통해 미션 시작 신호를 받으면 nav2로 레일 앞까지 이동
2. 1이 성공했다면 ros2 action send_goal /rail_approach interfaces_pkg/action/RailApproach "{timeout_sec: 20.0, x_tolerance: 0.25, angle_tolerance: 5.0, allow_reverse_align: false}"
3. 레일 정상적으로 올라가지면 ON_RAIL이 STM에서 시리얼로 나옴(레일에서 탈출하면 OUT_RAIL이 나옴)
4. 3초 forward 전송 -> stop 전송 -> 5초 대기 -> 2초 back 전송 -> stop 전송 -> 5초 대기 -> back 전송(레일에서 벗어나기 위함) 3번 항목은 전부 /rail_command으로 발행해야함
5. STM에서 OUT_RAIL -> home 위치로 이동 -> 미션 종료

홈위치 : <GoToPose x="1.2145" y="-0.7806" yaw="3.1125"/>
1번 레일 x: -0.9062973260879517, y: -2.77840256690979

+) 레일 진입 전 배터리 노드 필요
-->1-2 . 배터리 노드에서 배터리 잔량이 20% 이하이면 미션 중단하고 바로 홈으로 복귀하도록 함

<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="MissionWithReturnHome">

      <!-- 초기 변수 설정 -->
      <SetBlackboard output_key="mission_return_mode" value="DIRECT"/>
      <SetBlackboard output_key="last_executed_index" value="0"/>
      <SetBlackboard output_key="return_mode" value="MISSION_COMPLETE"/>
      <!-- 1. 미션 트리거 대기 -->
      <WaitForMissionTrigger selected_rails="{selected_rails}"/>
      <!-- 2. 실시간 모니터링 및 미션 수행 -->
      <ForceSuccess>
        <ReactiveFallback name="ReturnHomeMonitor">

          <Sequence name="LowBatteryRecovery">
            <IsBatteryLow threshold="20.0" recovery_threshold="90.0"/>
            <!-- 중단 시점의 목표 레일 좌표 및 현재 로봇 좌표 저장 -->
            <SaveCurrentPose save_x="{resume_x}" save_y="{resume_y}" save_yaw="{resume_yaw}"/>
            <!-- 현재 상태에 따라 레일에서 안전하게 빠져나오기 -->
            <Switch3 variable="{mission_return_mode}" case_1="EXIT_RAIL_HOME" case_2="REVERSE_HOME" case_3="DIRECT">
              <Sequence name="LeaveRailSafely">
                <PublishRailCommand command="BACK"/>
                <WaitForRailState state="OUT_RAIL" accept_stale="false" timeout_sec="30.0"/>
                <PublishRailCommand command="OUT"/>
                <WaitSeconds seconds="10.0"/>
                <DriveCmdVel linear_x="-0.25" angular_z="0.0" seconds="3.0"/>
              </Sequence>
              <Sequence name="ReverseSafely">
                <DriveCmdVel linear_x="-0.25" angular_z="0.0" seconds="3.0"/>
              </Sequence>
              <AlwaysSuccess/>
            </Switch3>

            <!-- 홈으로 이동하여 충전 대기 -->
            <GoToPose x="1.2145" y="-0.7806" yaw="3.1125"/>
            <WaitForCharge target_battery="90.0"/>

            <!-- 충전 완료 후, 아까 작업이 중단되었던 위치 근처(레일 진입 전)로 복귀 -->
            <SetBlackboard output_key="mission_return_mode" value="DIRECT"/>
            <GoToPose x="{resume_x}" y="{resume_y}" yaw="{resume_yaw}"/>
          </Sequence>


          <Sequence name="MultiRailMission">
            <Inverter>
              <ReturnHomeRequested return_mode="{return_mode}"/>
            </Inverter>

            <ForEachRail rail_list="{selected_rails}" current_rail="{rail_id}" 
              start_index="{last_executed_index}" last_executed_index="{last_executed_index}">
              <SubTreePlus
                ID="RailRoutine"
                rail_id="{rail_id}"
                mission_return_mode="{mission_return_mode}"
                __autoremap="1"/>
            </ForEachRail>

            <GoToPose x="1.2145" y="-0.7806" yaw="3.1125"/>
            <SetBlackboard output_key="return_mode" value="MISSION_COMPLETE"/>
          </Sequence>
        </ReactiveFallback>
      </ForceSuccess>

      <Switch3
        variable="{return_mode}"
        case_1="EXIT_RAIL_HOME"
        case_2="REVERSE_HOME"
        case_3="DIRECT">
        <Sequence name="LeaveRailAndReturnHome">
          <PublishRailCommand command="BACK"/>
          <WaitForRailState state="OUT_RAIL" accept_stale="false" timeout_sec="30.0"/>
          <PublishRailCommand command="OUT"/>
          <WaitSeconds seconds="10.0"/>
          <DriveCmdVel linear_x="-0.25" angular_z="0.0" seconds="3.0"/>
          <SetBlackboard output_key="mission_return_mode" value="DIRECT"/>
          <GoToPose x="1.2145" y="-0.7806" yaw="3.1125"/>
        </Sequence>

        <Sequence name="ReverseAndReturnHome">
          <DriveCmdVel linear_x="-0.25" angular_z="0.0" seconds="3.0"/>
          <SetBlackboard output_key="mission_return_mode" value="DIRECT"/>
          <GoToPose x="1.2145" y="-0.7806" yaw="3.1125"/>
        </Sequence>

        <GoToPose x="1.2145" y="-0.7806" yaw="3.1125"/>
        <AlwaysSuccess/>
      </Switch3>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="RailRoutine">
    <Sequence name="RailRoutineSequence">
      <SetBlackboard output_key="mission_return_mode" value="DIRECT"/>
      <GetRailPose rail_id="{rail_id}" x="{rail_x}" y="{rail_y}" yaw="{rail_yaw}"/>
      <GoToPose x="{rail_x}" y="{rail_y}" yaw="{rail_yaw}"/>
      <SetBlackboard output_key="mission_return_mode" value="REVERSE_HOME"/>
      <RailApproach
        timeout_sec="20.0"
        x_tolerance="0.25"
        angle_tolerance="5.0"
        allow_reverse_align="true"/>

      <SetBlackboard output_key="mission_return_mode" value="EXIT_RAIL_HOME"/>
      <WaitSeconds seconds="10.0"/>
      <PublishRailCommand command="ON"/>
      <PublishRailCommand command="FORWARD"/>
      <WaitSeconds seconds="5.0"/>
      <PublishRailCommand command="STOP"/>
      <WaitSeconds seconds="5.0"/>
      <PublishRailCommand command="BACK"/>
      <WaitSeconds seconds="5.0"/>
      <PublishRailCommand command="STOP"/>
      <WaitSeconds seconds="5.0"/>
      <PublishRailCommand command="OUT"/>
      <SetBlackboard output_key="mission_return_mode" value="REVERSE_HOME"/>
      <WaitSeconds seconds="10.0"/>
      <!-- 안전거리 후진 3초: /cmd_vel linear.x=-0.25 m/s, 완료/halt 시 0 발행 -->
      <DriveCmdVel linear_x="-0.25" angular_z="0.0" seconds="3.0"/>
      <SetBlackboard output_key="mission_return_mode" value="DIRECT"/>
    </Sequence>
  </BehaviorTree>
</root>
